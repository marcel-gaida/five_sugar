{
  "name": "Wayback Machine Link-Checker",
  "version": "2.0",
  "description": "Right-click any link or page to check its Wayback Machine archive. Browse cached snapshots, view the timeline, save pages locally.",
  "manifest_version": 3,
  "permissions": ["contextMenus", "activeTab", "downloads", "scripting"],
  "host_permissions": [
    "<all_urls>",
    "https://web.archive.org/*"
  ],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png"
    },
    "default_title": "Wayback Machine Link-Checker"
  },
  "background": {
    "service_worker": "background.js"
  },
  "homepage_url": "https://bmc.link/gaidamarcel"
}